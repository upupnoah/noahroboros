# noahroboros configuration
# Copy to .env and fill in your values: cp .env.example .env

# --- Backtest ---
INITIAL_CAPITAL=100000.0
POSITION_SIZE_FRAC=0.08
FEE_BPS=5.0
SLIPPAGE_BPS=1.0
DATA_DIR=data

# --- Scoring (Nunchi-style) ---
# Bars per year: 8760 (1h), 525600 (1m), 105120 (5m), 35040 (15m)
SHARPE_ANNUALIZE=8760.0
DD_FREE_PCT=15.0
DD_PENALTY_MULT=0.05
TURNOVER_FREE=500.0
TURNOVER_PENALTY_MULT=0.001

# --- Data Download ---
DOWNLOAD_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
DOWNLOAD_INTERVAL=1h
DOWNLOAD_MONTHS=9
DOWNLOAD_MARKET=spot

# --- Binance ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://api.binance.com

# --- Lighter.xyz ---
LIGHTER_API_URL=https://mainnet.zklighter.elliot.ai/api/v1
