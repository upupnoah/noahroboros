# noahroboros configuration
# Copy to .env and fill in your values: cp .env.example .env

# --- Backtest ---
DATA_DIR=data
INITIAL_CAPITAL=10000.0
POSITION_SIZE_FRAC=1.0

# --- Scoring weights (must sum to 1.0) ---
SCORE_W_SHARPE=0.4
SCORE_W_DRAWDOWN=0.3
SCORE_W_RETURN=0.2
SCORE_W_TURNOVER=0.1
SHARPE_ANNUALIZE=365.0

# --- Data Download ---
DOWNLOAD_SYMBOLS=BTCUSDT,ETHUSDT,SOLUSDT
DOWNLOAD_INTERVAL=1h
DOWNLOAD_MONTHS=9
# Market type: spot or futures (perpetual USDT-M)
DOWNLOAD_MARKET=spot

# --- Binance ---
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_BASE_URL=https://api.binance.com

# --- Lighter.xyz ---
LIGHTER_API_URL=https://mainnet.zklighter.elliot.ai/api/v1
